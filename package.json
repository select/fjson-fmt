{
  "name": "fjson-fmt",
  "version": "0.1.0",
  "description": "A Prettier-style check + write formatter for JSON using the FracturedJson algorithm (Rust engine compiled to WASM).",
  "type": "module",
  "author": "select",
  "repository": { "type": "git", "url": "git+https://github.com/select/fjson-fmt.git" },
  "homepage": "https://github.com/select/fjson-fmt#readme",
  "bugs": { "url": "https://github.com/select/fjson-fmt/issues" },
  "bin": {
    "fjson-fmt": "bin/fjson-fmt.mjs"
  },
  "files": [
    "bin",
    "lib",
    "pkg/fjson_fmt_engine.js",
    "pkg/fjson_fmt_engine.d.ts",
    "pkg/fjson_fmt_engine_bg.wasm",
    "pkg/fjson_fmt_engine_bg.wasm.d.ts",
    "README.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build:wasm": "wasm-pack build crate --target nodejs --out-dir ../pkg --release",
    "test": "node --test",
    "test:engine": "cargo test --manifest-path crate/Cargo.toml",
    "test:all": "npm run test && npm run test:engine",
    "prepublishOnly": "npm run build:wasm && npm run test:all"
  },
  "license": "MIT",
  "keywords": ["json", "jsonc", "formatter", "fracturedjson", "prettier", "wasm"]
}
